# Root-level .env for docker-compose (copy to .env and fill in values)

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# FastAPI backend — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_with_generated_secret

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://yourapp.com

# Frontend URL (used by backend for payment callbacks, password reset links)
FRONTEND_URL=https://yourapp.com

# Next.js — public API URL visible in browser
NEXT_PUBLIC_API_URL=https://yourapp.com/api/v1
